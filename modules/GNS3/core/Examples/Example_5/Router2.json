{
  "export": {
    "/interface ethernet": [
      {
        "cmd": "set",
        "default-name": "ether1",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether2",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether3",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether4",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether5",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether6",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether7",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether8",
        "disable-running-check": "no"
      }
    ],
    "/interface wireless security-profiles": [
      {
        "cmd": "set",
        "default": "yes",
        "supplicant-identity": "MikroTik"
      }
    ],
    "/ip address": [
      {
        "cmd": "add",
        "address": "10.100.4.2/30",
        "interface": "ether3",
        "network": "10.100.4.0"
      },
      {
        "cmd": "add",
        "address": "10.100.2.2/30",
        "interface": "ether1",
        "network": "10.100.2.0"
      },
      {
        "cmd": "add",
        "address": "10.0.20.254/24",
        "interface": "ether2",
        "network": "10.0.20.0"
      }
    ],
    "/ip dhcp-client": [
      {
        "cmd": "add",
        "disabled": "no",
        "interface": "ether1"
      }
    ],
    "/ip dns": [
      {
        "cmd": "set",
        "servers": "8.8.8.8,8.8.4.4"
      }
    ]
  }
}