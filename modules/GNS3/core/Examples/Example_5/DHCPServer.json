{
  "export": {
    "/interface ethernet": [
      {
        "cmd": "set",
        "default-name": "ether1",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether2",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether3",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether4",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether5",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether6",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether7",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether8",
        "disable-running-check": "no"
      }
    ],
    "/interface wireless security-profiles": [
      {
        "cmd": "set",
        "default": "yes",
        "supplicant-identity": "MikroTik"
      }
    ],
    "/ip pool": [
      {
        "cmd": "add",
        "name": "PoolNet1",
        "ranges": "10.0.10.2-10.0.10.253"
      },
      {
        "cmd": "add",
        "name": "PoolNetHQ",
        "ranges": "10.0.30.2-10.0.30.253"
      }
    ],
    "/ip dhcp-server": [
      {
        "cmd": "add",
        "address-pool": "PoolNet1",
        "disabled": "no",
        "interface": "ether1",
        "name": "dhcp1",
        "relay": "\\"
      },
      {
        "cmd": "10.0.10.254"
      },
      {
        "cmd": "add",
        "address-pool": "PoolNetHQ",
        "disabled": "no",
        "interface": "ether1",
        "name": "dhcp2",
        "relay": "\\"
      },
      {
        "cmd": "10.0.30.254"
      }
    ],
    "/ip address": [
      {
        "cmd": "add",
        "address": "10.0.20.1/24",
        "interface": "ether1",
        "network": "10.0.20.0"
      }
    ],
    "/ip dhcp-server network": [
      {
        "cmd": "add",
        "address": "10.0.10.0/24",
        "dns-server": "8.8.8.8,8.8.4.4",
        "gateway": "10.0.10.254"
      },
      {
        "cmd": "add",
        "address": "10.0.30.0/24",
        "dns-server": "8.8.8.8,8.8.4.4",
        "gateway": "10.0.30.254"
      }
    ]
  }
}