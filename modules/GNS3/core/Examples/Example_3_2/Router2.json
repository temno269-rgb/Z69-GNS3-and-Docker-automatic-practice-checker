{
  "export": {
    "/interface ethernet": [
      {
        "cmd": "set",
        "default-name": "ether1",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether2",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether3",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether4",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether5",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether6",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether7",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether8",
        "disable-running-check": "no"
      }
    ],
    "/interface wireless security-profiles": [
      {
        "cmd": "set",
        "default": "yes",
        "supplicant-identity": "MikroTik"
      }
    ],
    "/ip pool": [
      {
        "cmd": "add",
        "name": "pool1",
        "ranges": "10.0.40.1-10.0.40.253"
      }
    ],
    "/ip dhcp-server": [
      {
        "cmd": "add",
        "address-pool": "pool1",
        "disabled": "no",
        "interface": "ether1",
        "lease-time": "1d",
        "name": "dhcp1"
      }
    ],
    "/ip address": [
      {
        "cmd": "add",
        "address": "10.0.40.254/24",
        "interface": "ether1",
        "network": "10.0.40.0"
      },
      {
        "cmd": "add",
        "address": "192.168.0.2/30",
        "interface": "ether4",
        "network": "192.168.0.0"
      }
    ],
    "/ip dhcp-relay": [
      {
        "cmd": "add",
        "dhcp-server": "10.0.30.1",
        "disabled": "no",
        "interface": "ether1",
        "local-address": "\\"
      },
      {
        "cmd": "10.0.40.254",
        "name": "DHCP-Relay"
      }
    ],
    "/ip dhcp-server network": [
      {
        "cmd": "add",
        "address": "10.0.40.0/24",
        "dns-server": "8.8.8.8,8.8.4.4",
        "gateway": "10.0.40.254"
      }
    ],
    "/routing rip interface": [
      {
        "cmd": "add",
        "interface": "ether4"
      },
      {
        "cmd": "add",
        "interface": "ether1",
        "passive": "yes"
      }
    ],
    "/routing rip neighbor": [
      {
        "cmd": "add",
        "address": "192.168.0.1"
      }
    ],
    "/routing rip network": [
      {
        "cmd": "add",
        "network": "10.0.40.0/24"
      },
      {
        "cmd": "add",
        "network": "192.168.0.0/30"
      }
    ],
    "/system identity": [
      {
        "cmd": "set",
        "name": "Router2"
      }
    ]
  }
}