{
  "export": {
    "/interface ethernet": [
      {
        "cmd": "set",
        "default-name": "ether1",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether2",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether3",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether4",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether5",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether6",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether7",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether8",
        "disable-running-check": "no"
      }
    ],
    "/interface wireless security-profiles": [
      {
        "cmd": "set",
        "default": "yes",
        "supplicant-identity": "MikroTik"
      }
    ],
    "/ip pool": [
      {
        "cmd": "add",
        "name": "pool2",
        "ranges": "10.0.2.1-10.0.2.253"
      }
    ],
    "/ip dhcp-server": [
      {
        "cmd": "add",
        "address-pool": "pool2",
        "disabled": "no",
        "interface": "ether1",
        "lease-time": "1d",
        "name": "dhcp2"
      }
    ],
    "/ip address": [
      {
        "cmd": "add",
        "address": "10.0.2.254/24",
        "interface": "ether1",
        "network": "10.0.2.0"
      },
      {
        "cmd": "add",
        "address": "192.168.0.2/30",
        "interface": "ether2",
        "network": "192.168.0.0"
      }
    ],
    "/ip dhcp-server network": [
      {
        "cmd": "add",
        "address": "10.0.2.0/24",
        "dns-server": "8.8.8.8,8.8.4.4",
        "gateway": "10.0.2.254"
      }
    ],
    "/ip route": [
      {
        "cmd": "add",
        "distance": "1",
        "dst-address": "10.0.1.0/24",
        "gateway": "192.168.0.1"
      }
    ],
    "/system identity": [
      {
        "cmd": "set",
        "name": "R2"
      }
    ]
  }
}