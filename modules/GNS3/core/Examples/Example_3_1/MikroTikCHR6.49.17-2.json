{
  "export": {
    "/interface ethernet": [
      {
        "cmd": "set",
        "default-name": "ether1",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether2",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether3",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether4",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether5",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether6",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether7",
        "disable-running-check": "no"
      },
      {
        "cmd": "set",
        "default-name": "ether8",
        "disable-running-check": "no"
      }
    ],
    "/interface wireless security-profiles": [
      {
        "cmd": "set",
        "default": "yes",
        "supplicant-identity": "MikroTik"
      }
    ],
    "/ip address": [
      {
        "cmd": "add",
        "address": "192.168.2.1/25",
        "interface": "ether3",
        "network": "192.168.2.0"
      },
      {
        "cmd": "add",
        "address": "192.168.4.1/30",
        "interface": "ether1",
        "network": "192.168.4.0"
      },
      {
        "cmd": "add",
        "address": "192.168.0.1/21",
        "interface": "ether2",
        "network": "192.168.0.0"
      }
    ],
    "/routing rip interface": [
      {
        "cmd": "add",
        "interface": "ether1",
        "receive": "v2"
      },
      {
        "cmd": "add",
        "interface": "ether2",
        "passive": "yes"
      },
      {
        "cmd": "add",
        "interface": "ether3",
        "passive": "yes"
      }
    ]
  }
}